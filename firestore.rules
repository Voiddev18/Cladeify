rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user the admin? 
    function isAdmin() {
      return request.auth != null && (request.auth.uid == 'CkNq6106jmdYcRyqm4vVsbXFEF52'); 
    }

    match /leaderboard/{docId} {
      allow read: if true;
      
      // Allow deletion only if Admin or the owner
      allow delete: if isAdmin() || (request.auth != null && request.auth.uid == docId) || (request.auth == null && resource.data.localId == docId);

      // Create: Allow anyone to create their initial entry
      allow create: if (request.auth != null && request.auth.uid == docId) || (request.auth == null && request.resource.data.localId == docId);

      // Update: This is where we prevent cheating
      allow update: if isAdmin() || (
        // Must be the owner
        ((request.auth != null && request.auth.uid == docId) || (request.auth == null && request.resource.data.localId == docId)) &&
        
        // --- ANTI-CHEAT VALIDATIONS ---
        
        // 1. Points cannot jump by more than 50 in one sync
        (request.resource.data.points <= resource.data.points + 50) &&
        
        // 2. XP cannot jump by more than 1000 in one sync
        (request.resource.data.xp <= resource.data.xp + 1000) &&
        
        // 3. Prevent 'decreasing' stats (simple protection against resets)
        (request.resource.data.points >= resource.data.points) &&
        (request.resource.data.xp >= resource.data.xp) &&
        
        // 4. Critical fields cannot be changed (Usernames/LowerNames)
        (request.resource.data.name == resource.data.name) &&
        (request.resource.data.nameLower == resource.data.nameLower)
      );
    }
  }
}

