rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Leaderboard: anyone can read, anyone can write to their own doc
    // Authenticated users use their UID, anonymous users use a client-generated ID
    match /leaderboard/{docId} {
      allow read: if true;
      // Auth'd users can only write their own doc (uid == docId)
      allow write: if request.auth != null && request.auth.uid == docId;
      // Allow unauthenticated writes if the doc ID matches the localId field
      allow create, update: if request.auth == null
        && request.resource.data.localId == docId
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 20
        && request.resource.data.nameLower == request.resource.data.name.lower();
      allow delete: if request.auth == null && resource.data.localId == docId;
    }
  }
}
